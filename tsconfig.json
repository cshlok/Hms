{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".", 
    "paths": {
      "@/*": [
        "./apps/hms-web/src/*",
        "./src/*"
      ]
    },
    "types": [
      "@cloudflare/workers-types"
    ]
  },
  "include": [
    "apps/hms-web/.next/types/**/*.ts",
    "apps/hms-web/env.d.ts",
    "apps/hms-web/next-env.d.ts",
    "apps/hms-web/src/**/*.ts",
    "apps/hms-web/src/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "implementation/**/*.ts",
    "implementation/**/*.tsx",
    "next.config.mjs",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
