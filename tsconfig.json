{
  "compilerOptions": {
    "target": "ES2017", // From origin/master (more modern)
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true, // From HEAD
    "noUnusedParameters": true, // From HEAD
    "noImplicitReturns": true, // From HEAD
    "noFallthroughCasesInSwitch": true, // From HEAD
    "forceConsistentCasingInFileNames": true, // From HEAD
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler", // From origin/master (preferred for Next.js)
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["@cloudflare/workers-types"] // From HEAD (more general)
  },
  "include": [
    "next-env.d.ts",
    "env.d.ts", // From origin/master
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next.config.mjs" // From origin/master
  ],
  "exclude": [
    "node_modules",
    "home/ubuntu/logs_and_configs" // From HEAD
  ]
}
