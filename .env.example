# Environment Variables
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hms
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Password Hashing
SALT_ROUNDS=10

# Logging
LOG_LEVEL=info

# Environment
NODE_ENV=development
